#!/bin/sh
# ============================================================
#  router-api  —  通用 OpenWrt REST API
#  兼容：标准 OpenWrt / ImmortalWrt / LEDE / iStoreOS
#  依赖：ubus, uci, jsonfilter（所有版本预装）
#  可选增强：有 luci 时自动支持 session 登录
# ============================================================

# ---- 工具检测 ----
HAS_UCI=0
HAS_UBUS=0
HAS_JSONFILTER=0
HAS_LUCI=0

command -v uci >/dev/null 2>&1 && HAS_UCI=1
command -v ubus >/dev/null 2>&1 && HAS_UBUS=1
command -v jsonfilter >/dev/null 2>&1 && HAS_JSONFILTER=1
[ -f /usr/lib/lua/luci/json.lua ] && HAS_LUCI=1

# ---- 响应头 ----
echo "Content-Type: application/json; charset=utf-8"
echo "Access-Control-Allow-Origin: *"
echo "Access-Control-Allow-Headers: Content-Type, X-Auth-Token"
echo "Cache-Control: no-cache"
echo ""

# ---- 简易 JSON 构造（零依赖）----
json_escape() {
    sed 's/\\/\\\\/g; s/"/\\"/g; s/\t/\\t/g; s/\n/\\n/g' 2>/dev/null || cat
}

json_obj() {
    local first=1
    printf '{'
    while [ $# -ge 2 ]; do
        local k="$1" v="$2"; shift 2
        [ $first -eq 1 ] && first=0 || printf ','
        printf '"%s":"%s"' "$k" "$(echo "$v" | json_escape)"
    done
    printf '}'
}

json_obj_num() {
    local first=1
    printf '{'
    while [ $# -ge 2 ]; do
        local k="$1" v="$2"; shift 2
        [ $first -eq 1 ] && first=0 || printf ','
        printf '"%s":%s' "$k" "$v"
    done
    printf '}'
}

# ---- 错误响应 ----
json_error() {
    local code="${1:-1}"
    local msg="${2:-unknown error}"
    printf '{"code":%d,"msg":"%s"}\n' "$code" "$(echo "$msg" | json_escape)"
    exit 0
}

# ---- 简易 Token 认证 ----
AUTH_ENABLED=0
AUTH_TOKEN=""

if [ "$HAS_UCI" = "1" ]; then
    AUTH_ENABLED=$(uci -q get router-api.config.auth_enabled 2>/dev/null || echo 0)
    AUTH_TOKEN=$(uci -q get router-api.config.auth_token 2>/dev/null || echo "")
fi

[ -z "$AUTH_TOKEN" ] && AUTH_TOKEN=$(cat /etc/router-api-token 2>/dev/null)
[ -n "$AUTH_TOKEN" ] && AUTH_ENABLED=1

check_auth() {
    [ "$AUTH_ENABLED" = "0" ] && return 0
    local client_token=""
    client_token=$(echo "$HTTP_X_AUTH_TOKEN" | head -1)
    [ -z "$client_token" ] && client_token=$(echo "$QUERY_STRING" | sed -n 's/.*token=\([^&]*\).*/\1/p')
    [ -z "$client_token" ] && client_token="${HTTP_COOKIE##*router_token=}"
    [ -z "$client_token" ] && json_error 401 "authentication required（请在 URL 加 ?token=xxx 或 Header X-Auth-Token）"
    [ "$client_token" != "$AUTH_TOKEN" ] && json_error 403 "Token错误"
    return 0
}

# ============================================================
#   处理函数（必须在 case 分发前定义！）
# ============================================================

get_cpu_usage() {
    # 第一次读取
    read -r _ u1 n1 s1 i1 w1 ir1 si1 _ < /proc/stat
    sleep 1
    # 第二次读取
    read -r _ u2 n2 s2 i2 w2 ir2 si2 _ < /proc/stat

    # 计算总时间差和空闲时间差
    total1=$((u1 + n1 + s1 + i1 + w1 + ir1 + si1))
    total2=$((u2 + n2 + s2 + i2 + w2 + ir2 + si2))
    idle1=$((i1 + w1))
    idle2=$((i2 + w2))

    delta_total=$((total2 - total1))
    delta_idle=$((idle2 - idle1))
    delta_used=$((delta_total - delta_idle))

    if [ "$delta_total" -gt 0 ]; then
        echo $((delta_used * 100 / delta_total))
    else
        echo 0
    fi
}

handle_system_info() {
    # 统一使用纯 shell 构造，避免 ubus 分支不一致
    local hostname=$(cat /proc/sys/kernel/hostname 2>/dev/null || echo "OpenWrt")
    local model=$(cat /tmp/sysinfo/model 2>/dev/null || cat /proc/device-tree/model 2>/dev/null || echo "Unknown")
    local kernel=$(uname -r 2>/dev/null || echo "unknown")
    local uptime=$(cut -d' ' -f1 /proc/uptime 2>/dev/null | cut -d'.' -f1 || echo 0)
    local local_time=$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "")

    # 获取 CPU 使用率（会阻塞 1 秒）
    local cpu_usage=$(get_cpu_usage)

    # 获取负载（/proc/loadavg 前三个字段）
    local load=""
    read -r load1 load5 load15 _ < /proc/loadavg 2>/dev/null
    load="[$load1, $load5, $load15]"

    # 获取内存（单位：KB）
    local mem_total=0 mem_free=0 mem_avail=0 mem_buffers=0 mem_cached=0
    while IFS=':' read -r key val; do
        val=$(echo "$val" | sed 's/[^0-9]*//g')
        case "$key" in
            MemTotal)     mem_total=$val ;;
            MemFree)      mem_free=$val ;;
            MemAvailable) mem_avail=$val ;;
            Buffers)      mem_buffers=$val ;;
            Cached)       mem_cached=$val ;;
        esac
    done < /proc/meminfo

    # 组装 JSON
    json_obj_num "code" 0 "data" "$(json_obj_num \
        "hostname" "\"$hostname\"" \
        "model" "\"$model\"" \
        "kernel" "\"$kernel\"" \
        "uptime" "$uptime" \
        "localtime" "$(date +%s)" \
        "load" "$load" \
        "cpu_usage" "$cpu_usage" \
        "memory" "$(json_obj_num \
            "total" "$mem_total" \
            "free" "$mem_free" \
            "available" "$mem_avail" \
            "buffers" "$mem_buffers" \
            "cached" "$mem_cached")" \
        "root" "$(df / | awk 'NR==2{printf "{\"total\":%d,\"free\":%d,\"used\":%d,\"avail\":%d}",$2,$4,$3,$4}')" \
        "tmp" "$(df /tmp | awk 'NR==2{printf "{\"total\":%d,\"free\":%d,\"used\":%d,\"avail\":%d}",$2,$4,$3,$4}')" \
    )"
}

handle_system_board() {
    if [ "$HAS_UBUS" = "1" ]; then
        local info
        info=$(ubus call system board 2>/dev/null)
        if [ -n "$info" ]; then
            info_clean=$(printf '%s' "$info" | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' 2>/dev/null)
            case "$info_clean" in
                '{'*'}')
                    if printf '%s\n' "$info_clean" | jsonfilter -e '@' >/dev/null 2>&1; then
                        printf '{"code":0,"data":%s}\n' "$info_clean"
                        return
                    fi
                    ;;
            esac
        fi
    fi

    if [ -f /tmp/sysinfo/board_name ]; then
        local board=$(cat /tmp/sysinfo/board_name 2>/dev/null)
        local model=$(cat /tmp/sysinfo/model 2>/dev/null)
        json_obj_num "code" 0 "data" "$(json_obj "board" "$board" "model" "$model")"
        return
    fi

    json_error 500 "board info unavailable"
}

handle_network_interfaces() {
    # 先计算实时网速（每次请求都更新）
    local rates
    rates=$(get_network_rates)

    if [ "$HAS_UBUS" = "1" ]; then
        local data
        data=$(ubus call network.interface dump 2>/dev/null)
        if [ -n "$data" ]; then
            data_clean=$(printf '%s' "$data" | tr -d '\n\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' 2>/dev/null)
            case "$data_clean" in
                '{'*'}'|'['*']')
                    if printf '%s\n' "$data_clean" | jsonfilter -e '@' >/dev/null 2>&1; then
                        # ubus 数据 + 速率（客户端按 iface/interface 字段合并）
                        printf '{"code":0,"data":%s,"rates":%s}\n' "$data_clean" "$rates"
                        return
                    fi
                    ;;
            esac
        fi
    fi

    # 降级：从 /proc/net/dev + 速率计算结果构建响应
    printf '{"code":0,"data":{"interfaces":%s}}\n' "$rates"
}

handle_network_wifi() {
    if [ "$HAS_UBUS" = "1" ]; then
        local data
        data=$(ubus call iwinfo info 2>/dev/null)
        if [ -z "$data" ]; then
            data=$(ubus call network.wireless status 2>/dev/null)
        fi
        if [ -n "$data" ] && [ "$HAS_JSONFILTER" = "1" ]; then
            printf '%s\n' "$data" | jsonfilter -e "code=0" -e "data=@"
            return
        fi
    fi

    if command -v iwinfo >/dev/null 2>&1; then
        local wifi_json="["
        local first=1
        for dev in $(iwinfo 2>/dev/null | grep -oE 'wlan[0-9]+|phy[0-9]+-ap[0-9]+'); do
            [ "$first" -eq 1 ] && first=0 || wifi_json="${wifi_json},"
            local ssid=$(iwinfo "$dev" info 2>/dev/null | grep -i "ESSID" | sed 's/.*ESSID: "\(.*\)"/\1/')
            [ -z "$ssid" ] && ssid=""
            wifi_json="${wifi_json}{\"device\":\"${dev}\",\"ssid\":\"${ssid}\"}"
        done
        wifi_json="${wifi_json}]"
        printf '{"code":0,"data":%s}\n' "$wifi_json"
    else
        json_error 500 "iwinfo not available"
    fi
}

# ---- 网速速率计算（从 /proc/net/dev 两次采样对比）----
get_network_rates() {
    # 第一次快照
    local snap1=$(cat /proc/net/dev)
    sleep 1
    # 第二次快照
    local snap2=$(cat /proc/net/dev)

    # 使用 awk 对比两个快照（通过变量传递，而不是文件）
    awk -v s1="$snap1" -v s2="$snap2" '
    BEGIN {
        # 解析第一次快照，存入数组
        split(s1, lines1, "\n")
        for (i in lines1) {
            if (lines1[i] ~ /:/ && lines1[i] !~ /^[ ]*lo:/) {
                split(lines1[i], f)
                iface = f[1]; sub(/:$/, "", iface)
                rx1[iface] = f[2]
                tx1[iface] = f[10]
            }
        }
        # 解析第二次快照并输出
        split(s2, lines2, "\n")
        first = 1
        printf "["
        for (i in lines2) {
            if (lines2[i] ~ /:/ && lines2[i] !~ /^[ ]*lo:/) {
                split(lines2[i], f)
                iface = f[1]; sub(/:$/, "", iface)
                rx2 = f[2]; tx2 = f[10]
                rx_rate = (rx2 - rx1[iface] >= 0) ? (rx2 - rx1[iface]) : 0
                tx_rate = (tx2 - tx1[iface] >= 0) ? (tx2 - tx1[iface]) : 0
                if (!first) printf ","
                first = 0
                printf "{\"iface\":\"%s\",\"rx_bytes\":%d,\"tx_bytes\":%d,\"rx_rate\":%d,\"tx_rate\":%d}", iface, rx2, tx2, rx_rate, tx_rate
            }
        }
        printf "]\n"
    }'
}

handle_network_devices() {
    if [ "$HAS_UBUS" = "1" ]; then
        local data
        data=$(ubus call network.device status 2>/dev/null)
        if [ -n "$data" ] && [ "$HAS_JSONFILTER" = "1" ]; then
            printf '%s\n' "$data" | jsonfilter -e "code=0" -e "data=@"
            return
        fi
    fi
    json_error 500 "network.device ubus unavailable"
}

handle_dhcp_leases() {
    local leases_json="["
    local first=1

    if [ -f /tmp/dhcp.leases ]; then
        while IFS=' ' read -r timestamp mac ip name _; do
            [ "$first" -eq 1 ] && first=0 || leases_json="${leases_json},"
            leases_json="${leases_json}{\"mac\":\"${mac}\",\"ip\":\"${ip}\",\"name\":\"${name}\",\"expires\":${timestamp}}"
        done < /tmp/dhcp.leases
    fi
    leases_json="${leases_json}]"
    printf '{"code":0,"data":%s}\n' "$leases_json"
}

handle_storage_info() {
    local mounts_json="["
    local first=1

    while IFS=' ' read -r dev mnt fs _; do
        case "$dev" in
            /dev/*)
                local total=0 used=0 free=0
                if command -v df >/dev/null 2>&1; then
                    read -r _ total used free _ <<EOF
$(df -k "$mnt" 2>/dev/null | tail -1)
EOF
                fi
                [ "$first" -eq 1 ] && first=0 || mounts_json="${mounts_json},"
                mounts_json="${mounts_json}{\"device\":\"${dev}\",\"mount\":\"${mnt}\",\"fs\":\"${fs}\",\"total_kb\":${total:-0},\"used_kb\":${used:-0},\"free_kb\":${free:-0}}"
                ;;
        esac
    done < /proc/mounts

    mounts_json="${mounts_json}]"
    printf '{"code":0,"data":%s}\n' "$mounts_json"
}

handle_memory_info() {
    local total=0 free=0 avail=0 cached=0 buffers=0
    while IFS=':' read -r key val; do
        val=$(echo "$val" | sed 's/[^0-9]*//g')
        case "$key" in
            MemTotal)  total=$val ;;
            MemFree)   free=$val ;;
            MemAvailable) avail=$val ;;
            Cached)    cached=$val ;;
            Buffers)   buffers=$val ;;
        esac
    done < /proc/meminfo

    local used=$((total - free))
    [ "$avail" = "0" ] && avail=$((free + buffers + cached))

    printf '{"code":0,"data":{"total_kb":%d,"free_kb":%d,"available_kb":%d,"used_kb":%d,"buffers_kb":%d,"cached_kb":%d}}\n' \
        "$total" "$free" "$avail" "$used" "$buffers" "$cached"
}

get_cpu_temp() {
    for zone in /sys/class/thermal/thermal_zone*; do
        [ -e "$zone/type" ] || continue
        local type=$(cat "$zone/type" 2>/dev/null)
        if [ "$type" = "x86_pkg_temp" ] || [ "$type" = "soc-thermal" ]; then
            local temp_raw=$(cat "$zone/temp" 2>/dev/null)
            echo $((temp_raw / 1000))
            return
        fi
    done
    if [ -r /sys/class/thermal/thermal_zone0/temp ]; then
        echo $(( $(cat /sys/class/thermal/thermal_zone0/temp) / 1000 ))
        return
    fi
    echo 0
}

handle_cpu_info() {
    local usage=0
    read -r _ user nice system idle iowait irq softirq _ < /proc/stat
    local total=$((user + nice + system + idle + iowait + irq + softirq))
    local used=$((total - idle - iowait))
    [ "$total" -gt 0 ] && usage=$((used * 100 / total))

    local model=$(grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^[ \t]*//')
    local cores=$(grep -c processor /proc/cpuinfo 2>/dev/null)
    local cpu_temp=$(get_cpu_temp)

    json_obj_num "code" 0 "data" "$(json_obj_num \
        "usage_percent" "$usage" \
        "model" "\"${model:-Unknown}\"" \
        "cores" "${cores:-0}" \
        "cpu_temp" "${cpu_temp}")"
}

handle_processes() {
    # 可通过 ?top=10 控制返回数量，默认 10
    local top_n=20

    # 获取系统时钟频率（默认 100）和运行时间（秒）
    local HZ=$(getconf CLK_TCK 2>/dev/null || echo 100)
    local uptime_sec=$(cut -d' ' -f1 /proc/uptime 2>/dev/null | cut -d'.' -f1)
    [ -z "$uptime_sec" ] && uptime_sec=0

    local tmp1="/tmp/procs_$$_1"
    local tmp2="/tmp/procs_$$_2"
    > "$tmp1"

    # 遍历所有进程
    for status in /proc/[0-9]*/status; do
        [ -f "$status" ] || continue
        local dir="${status%/status}"
        local pid="${dir##*/}"
        local comm=$(cat "/proc/$pid/comm" 2>/dev/null)
        [ -z "$comm" ] && continue

        # 物理内存
        local rss=$(awk '/^VmRSS:/{print $2}' "$status" 2>/dev/null)
        [ -z "$rss" ] && rss=0

        # 读取 /proc/[pid]/stat 获取 CPU 时间和启动时间
        local stat_line=$(cat "/proc/$pid/stat" 2>/dev/null)
        local utime=0 stime=0 starttime=0
        if [ -n "$stat_line" ]; then
            utime=$(echo "$stat_line" | awk '{print $14}')
            stime=$(echo "$stat_line" | awk '{print $15}')
            starttime=$(echo "$stat_line" | awk '{print $22}')
        fi

        # 计算平均 CPU 使用率（自进程启动以来）
        local cpu_percent=0
        if [ "$uptime_sec" -gt 0 ] && [ "$HZ" -gt 0 ]; then
            local total_jiffies=$((utime + stime))
            local proc_uptime_jiffies=$(( uptime_sec * HZ - starttime ))
            if [ "$proc_uptime_jiffies" -gt 0 ]; then
                cpu_percent=$(( total_jiffies * 100 / proc_uptime_jiffies ))
                [ "$cpu_percent" -gt 100 ] && cpu_percent=100
            fi
        fi

        # 记录到临时文件（字段：rss pid comm cpu_percent）
        echo "$rss $pid $comm $cpu_percent" >> "$tmp1"
    done

    # 按内存降序排序，取前 top_n 个
    sort -rn "$tmp1" | head -n "$top_n" > "$tmp2"

    # 构造 JSON
    local output="[" first=1
    while read -r rss pid comm cpu_percent; do
        [ -z "$pid" ] && continue
        local escaped_comm=$(echo "$comm" | sed 's/\\/\\\\/g; s/"/\\"/g')
        [ "$first" = "1" ] && first=0 || output="${output},"
        output="${output}{\"pid\":${pid},\"rss\":${rss},\"comm\":\"${escaped_comm}\",\"cpu_percent\":${cpu_percent}}"
    done < "$tmp2"

    output="${output}]"
    printf '{"code":0,"data":%s}\n' "$output"
    rm -f "$tmp1" "$tmp2"
}

handle_route_table() {
    printf '{"code":0,"data":['

    if command -v ip >/dev/null 2>&1; then
        local first=1
        ip route show 2>/dev/null | while read -r line; do
            [ -z "$line" ] && continue
            local dest="" gw="" dev="" src=""
            # 解析 ip route 输出
            dest=$(echo "$line" | awk '{print $1}')
            local rest=$(echo "$line" | sed 's/^[^ ]* //')
            gw=$(echo "$rest" | sed -n 's/.*via \([^ ]*\).*/\1/p')
            dev=$(echo "$rest" | sed -n 's/.*dev \([^ ]*\).*/\1/p')
            src=$(echo "$rest" | sed -n 's/.*src \([^ ]*\).*/\1/p')
            [ -z "$dest" ] && continue
            [ "$first" -eq 1 ] && first=0 || printf ','
            printf '{"destination":"%s","gateway":"%s","device":"%s","source":"%s","flags":"%s"}' \
                "$dest" "${gw:-}" "${dev:-}" "${src:-}" "$(echo "$line" | awk '{for(i=2;i<=NF;i++)if($i!~/dev|via|src|proto|scope|metric|link|src/&&$i!~/^[0-9]/){printf "%s ",$i}}')"
        done
    elif command -v route >/dev/null 2>&1; then
        local first=1
        route -n 2>/dev/null | tail -n +3 | while read -r dest gw _ flags _ _ _ iface; do
            [ -z "$dest" ] && continue
            [ "$first" -eq 1 ] && first=0 || printf ','
            printf '{"destination":"%s","gateway":"%s","device":"%s","source":"","flags":"%s"}' "$dest" "$gw" "$iface" "$flags"
        done
    fi

    printf ']}\n'
}

handle_startup_items() {
    if [ "$HAS_UBUS" = "1" ]; then
        local data
        data=$(ubus call rc list '{"verbose":true}' 2>/dev/null)
        if [ -n "$data" ]; then
            printf '{"code":0,"data":%s}\n' "$data"
            return
        fi
    fi
    printf '{"code":0,"data":{}}\n'
}

handle_uci_get() {
    [ "$HAS_UCI" = "0" ] && json_error 500 "uci not available"

    local config=$(echo "$QUERY_STRING" | sed -n 's/.*config=\([^&]*\).*/\1/p')
    local section=$(echo "$QUERY_STRING" | sed -n 's/.*section=\([^&]*\).*/\1/p')
    local option=$(echo "$QUERY_STRING" | sed -n 's/.*option=\([^&]*\).*/\1/p')

    [ -z "$config" ] && json_error 400 "missing config parameter"
    [ -z "$section" ] || [ -z "$option" ] && json_error 400 "missing section or option"

    local val=$(uci -q get "${config}.${section}.${option}" 2>/dev/null || echo "")
    json_obj_num "code" 0 "data" "$(json_obj "value" "$val")"
}

handle_uci_get_all() {
    [ "$HAS_UCI" = "0" ] && json_error 500 "uci not available"

    local config=$(echo "$QUERY_STRING" | sed -n 's/.*config=\([^&]*\).*/\1/p')
    [ -z "$config" ] && json_error 400 "missing config parameter"

    if command -v uci >/dev/null 2>&1; then
        local result=$(uci -q show "$config" 2>/dev/null)
        if [ -n "$result" ]; then
            local json="["
            local first=1
            while IFS='=' read -r key val; do
                [ "$first" -eq 1 ] && first=0 || json="${json},"
                json="${json}{\"key\":\"${key}\",\"value\":\"${val}\"}"
            done <<EOF
$result
EOF
            json="${json}]"
            printf '{"code":0,"data":%s}\n' "$json"
            return
        fi
    fi
    json_error 500 "uci show failed"
}

handle_reboot() {
    # 立即重启（可能需要几秒才断开连接）
    /sbin/reboot >/dev/null 2>&1
    # 返回成功信息（实际命令发出后，连接可能就断了）
    printf '{"code":0,"msg":"reboot signal sent, device will restart"}\n'
}

handle_factory_reset() {
    # 强制要求 confirm=yes 参数，防止误操作
    local confirm=$(echo "$QUERY_STRING" | sed -n 's/.*confirm=\([^&]*\).*/\1/p')
    if [ "$confirm" != "yes" ]; then
        json_error 400 "factory_reset requires ?confirm=yes"
        return
    fi

    # 执行恢复出厂设置（清除所有配置，下次重启生效）
    # firstboot 会删除 /overlay 等，然后自动重启
    if command -v firstboot >/dev/null 2>&1; then
        firstboot >/dev/null 2>&1 && reboot
        printf '{"code":0,"msg":"factory reset initiated, device will reboot"}\n'
    else
        json_error 500 "firstboot command not found"
    fi
}

handle_istore_apps() {
    local meta_dir="/usr/lib/opkg/meta"

    # 1. 检测 iStore 元数据目录
    if [ ! -d "$meta_dir" ]; then
        json_error 404 "iStore meta directory not found"
        return
    fi

    local output="["
    local first=1

    # 2. 遍历所有 .json 文件
    for f in "$meta_dir"/*.json; do
        [ -f "$f" ] || continue

        local name title version entry icon link

        # 3. 提取字段（优先使用 jsonfilter，不可用时降级为 grep/sed）
        if [ "$HAS_JSONFILTER" = "1" ]; then
            name=$(jsonfilter -i "$f" -e '@.name' 2>/dev/null)
            title=$(jsonfilter -i "$f" -e '@.title' 2>/dev/null)
            version=$(jsonfilter -i "$f" -e '@.version' 2>/dev/null)
            entry=$(jsonfilter -i "$f" -e '@.entry' 2>/dev/null)
        else
            # 降级方案（简单解析，假定字段在同一行，且值不含嵌套引号）
            name=$(grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' "$f" | head -1 | sed 's/.*"\(.*\)"/\1/')
            title=$(grep -o '"title"[[:space:]]*:[[:space:]]*"[^"]*"' "$f" | head -1 | sed 's/.*"\(.*\)"/\1/')
            version=$(grep -o '"version"[[:space:]]*:[[:space:]]*"[^"]*"' "$f" | head -1 | sed 's/.*"\(.*\)"/\1/')
            entry=$(grep -o '"entry"[[:space:]]*:[[:space:]]*"[^"]*"' "$f" | head -1 | sed 's/.*"\(.*\)"/\1/')
        fi

        # 没有 name 则跳过
        [ -z "$name" ] && continue

        # 4. 构造图标和应用链接
        icon="/luci-static/resources/app-icons/${name}.png"
        if [ -n "$entry" ]; then
            link="$entry"
        else
            # 若 entry 缺失，回退到通用模式（可能无效，但保持可读）
            link="/cgi-bin/luci/admin/services/${name}"
        fi

        # 5. 转义字符串中的特殊字符（主要针对双引号和反斜杠）
        name_esc=$(echo "$name" | sed 's/\\/\\\\/g; s/"/\\"/g')
        title_esc=$(echo "${title:-}" | sed 's/\\/\\\\/g; s/"/\\"/g')
        version_esc=$(echo "${version:-}" | sed 's/\\/\\\\/g; s/"/\\"/g')
        icon_esc=$(echo "$icon" | sed 's/\\/\\\\/g; s/"/\\"/g')
        link_esc=$(echo "$link" | sed 's/\\/\\\\/g; s/"/\\"/g')

        # 6. 拼接到数组
        [ "$first" = "1" ] && first=0 || output="${output},"
        output="${output}{\"name\":\"${name_esc}\",\"title\":\"${title_esc}\",\"version\":\"${version_esc}\",\"icon\":\"${icon_esc}\",\"link\":\"${link_esc}\"}"
    done

    output="${output}]"
    printf '{"code":0,"data":%s}\n' "$output"
}

# ---- 解析请求 ----
METHOD="${REQUEST_METHOD:-GET}"
QUERY_STRING="${QUERY_STRING:-}"
ACTION=""

if echo "$QUERY_STRING" | grep -q 'action='; then
    ACTION=$(echo "$QUERY_STRING" | sed 's/.*action=\([^&]*\).*/\1/')
elif [ -n "${PATH_INFO}" ]; then
    ACTION=$(echo "${PATH_INFO}" | sed 's|^/||; s|/|_|g')
fi

# ---- 路由表 ----
case "$ACTION" in
